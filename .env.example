# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# --- Compose ---
COMPOSE_PROJECT_NAME=freelancer_monitor

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=project_manager
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=project_manager
MYSQL_ROOT_PASSWORD=change_me_root

# --- Ollama (local LLM runtime) ---
# host.docker.internal works when Ollama runs on the Docker host (macOS/Windows).
# On Linux either run Ollama inside the compose stack or use the host gateway.
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral
# Optional: override generation budgets inside ollama-mcp.
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_JSON_NUM_PREDICT=16384

# --- MCP Servers ---
OLLAMA_MCP_HOST=ollama-mcp
OLLAMA_MCP_PORT=3100
PLAYWRIGHT_MCP_HOST=playwright-mcp
PLAYWRIGHT_MCP_PORT=3200

# --- Backend (NestJS) ---
BACKEND_PORT=4000
NODE_ENV=development

# --- Freelancermap ---
# Pre-filtered search URL (filters: category, created-today, remote, etc.).
FREELANCERMAP_SEARCH_URL=https://www.freelancermap.de/projekte?categories%5B0%5D=1&created=1&projectContractTypes%5B0%5D=contracting&remoteInPercent%5B0%5D=100
FREELANCERMAP_BASE_URL=https://www.freelancermap.de
FREELANCERMAP_EMAIL=your_account@example.com
FREELANCERMAP_PASSWORD=your_password
# Optional: FREELANCERMAP_MAX_LIST_PAGES=50
# Reject imports whose publish date is older than N days. Default: 2.
FREELANCERMAP_MAX_PROJECT_AGE_DAYS=2

# --- Polling ---
POLLING_INTERVAL_MINUTES=30

# --- Matching ---
# Minimum match rate (%) to auto-generate an application draft.
MATCHING_THRESHOLD_APPLICATION=40
# Match rate (%) that triggers an audible/visual alert.
MATCHING_THRESHOLD_VERY_HIGH=85
# Scoring weights.
WEIGHT_DIRECT=1.0
WEIGHT_ALTERNATIVE=0.5
WEIGHT_MUST_HAVE=2.0
WEIGHT_NICE_TO_HAVE=1.0

# --- Alerting ---
ALERT_AUDIO_FILE=/data/audio/alert.mp3

# --- Frontend (Vite) ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:4000
